{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Backend (uvicorn)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--host", "127.0.0.1", "--port", "8000"],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal"
    },
    {
      "name": "Seed DB (create admin)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/backend/scripts/seed_db.py",
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal"
    }
  ]
}
